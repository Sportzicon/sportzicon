# Production Environment Template
# Used for: Terraform deployment to GCP Cloud Run
# Copy this to .env.production and fill in YOUR production values
# ⚠️  SECURITY WARNING: This file contains production secrets
# - NEVER commit .env.production to git
# - ONLY store this in secure secret management system
# - In Cloud Run, secrets are injected via Terraform + Secret Manager
# File pattern: .env.production.example (COMMITTED to git - safe template)

NODE_ENV=production
PORT=8080

# Firestore Configuration (REAL GCP - PRODUCTION PROJECT)
GCP_PROJECT_ID=your-gcp-project-production
# NEVER set FIRESTORE_EMULATOR_HOST in production - use real Firestore
FIRESTORE_EMULATOR_HOST=

# GCS Configuration (REAL GCP - PRODUCTION PROJECT)
STORAGE_EMULATOR_HOST=
GCS_BUCKET_MEDIA=sportivox-media-prod
GCS_BUCKET_DOCS=sportivox-docs-prod
GCS_SIGNED_URL_TTL_MIN=15
MAX_UPLOAD_MB=10

# JWT Secrets (GENERATED BY TERRAFORM IN SECRET MANAGER)
# In Cloud Run, these are injected by Terraform automatically
# For local testing before deployment, generate strong random values:
# IMPORTANT: Use at least 64 random characters (no spaces, special chars only for hash)
JWT_ACCESS_SECRET=your-production-jwt-access-secret-min-64-chars-RANDOMLY-GENERATED
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-min-64-chars-RANDOMLY-GENERATED
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Security (STRICT FOR PRODUCTION)
BCRYPT_ROUNDS=12

# CORS - Only allow production frontend domain
CORS_ORIGINS=https://app.sportivox.com,https://api.sportivox.com

# URLs
WEB_APP_URL=https://app.sportivox.com
PUBLIC_API_URL=https://api.sportivox.com

# Rate Limiting (STRICT FOR PRODUCTION)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=warn

# Admin Bootstrap (OPTIONAL)
# Only set this for initial production setup
# After first login, IMMEDIATELY rotate the password
BOOTSTRAP_ADMIN_EMAIL=admin@sportivox.com
BOOTSTRAP_ADMIN_PASSWORD=GenerateStrongPasswordHere123!

# Email (OPTIONAL but RECOMMENDED for production)
# Set up SendGrid account and add API key here
SENDGRID_API_KEY=your-production-sendgrid-api-key

# AI Features (OPTIONAL)
# Set up OpenAI account and add API key here
OPENAI_API_KEY=your-production-openai-api-key
