# Frontend Production Environment Template
# Used with: npm run build
# Vite reads this for production builds
# ⚠️  Do not commit .env.production - this is a template

# Backend API URL - should point to your Cloud Run API service
VITE_API_BASE_URL=https://api.sportivox.com

# Feature flags for production
VITE_ENABLE_DEMO_MODE=false
VITE_LOG_LEVEL=error
