# Staging Environment Template
# Used for: docker compose -f docker-compose.prod.yml up --build
# Copy this file to .env.staging and fill in YOUR values
# This is a REAL GCP deployment (not emulators)
# File pattern: .env.staging.example (COMMITTED to git)

NODE_ENV=staging
PORT=8080

# Firestore Configuration (REAL GCP - STAGING PROJECT)
GCP_PROJECT_ID=your-gcp-project-staging
# NEVER set FIRESTORE_EMULATOR_HOST in staging - use real Firestore
FIRESTORE_EMULATOR_HOST=

# GCS Configuration (REAL GCP - STAGING PROJECT)
STORAGE_EMULATOR_HOST=
GCS_BUCKET_MEDIA=sportivox-media-staging
GCS_BUCKET_DOCS=sportivox-docs-staging
GCS_SIGNED_URL_TTL_MIN=15
MAX_UPLOAD_MB=10

# JWT Secrets (FROM GCP SECRET MANAGER - but can override locally)
# In production, these come from Cloud Run env vars set by Terraform
# For local testing, you can set them here temporarily
JWT_ACCESS_SECRET=your-staging-jwt-access-secret-min-64-chars-CHANGE-ME
JWT_REFRESH_SECRET=your-staging-jwt-refresh-secret-min-64-chars-CHANGE-ME
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Security (STANDARD FOR STAGING)
BCRYPT_ROUNDS=10

# CORS - Only allow staging frontend
CORS_ORIGINS=https://staging.sportivox.com,https://api-staging.sportivox.com

# URLs
WEB_APP_URL=https://staging.sportivox.com
PUBLIC_API_URL=https://api-staging.sportivox.com

# Rate Limiting (STANDARD FOR STAGING)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Logging
LOG_LEVEL=info

# Admin Bootstrap (OPTIONAL - use for first-time staging setup only)
BOOTSTRAP_ADMIN_EMAIL=admin@sportivox-staging.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeNow123!

# Email (OPTIONAL - uses SendGrid if key provided)
SENDGRID_API_KEY=your-sendgrid-api-key-for-staging

# AI Features (OPTIONAL)
OPENAI_API_KEY=your-openai-api-key-for-staging
