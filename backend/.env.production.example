# Backend Production Configuration Template
# ⚠️  SECURITY: Do not commit .env.production - this is a template only
# In Cloud Run, these values are injected by Terraform from Secret Manager

NODE_ENV=production
PORT=8080

# Firestore Production
GCP_PROJECT_ID=your-production-gcp-project
FIRESTORE_EMULATOR_HOST=

# GCS Production
STORAGE_EMULATOR_HOST=
GCS_BUCKET_MEDIA=sportivox-media-prod
GCS_BUCKET_DOCS=sportivox-docs-prod

# JWT - MUST be strong random values (64+ chars)
JWT_ACCESS_SECRET=your-production-jwt-access-secret-generated-randomly
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-generated-randomly

# CORS - Production domain only
CORS_ORIGINS=https://app.sportivox.com

# URLs
WEB_APP_URL=https://app.sportivox.com
PUBLIC_API_URL=https://api.sportivox.com

# Rate Limits (Strict)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=warn

# Bootstrap Admin (Optional - set only for initial setup)
BOOTSTRAP_ADMIN_EMAIL=admin@sportivox.com
BOOTSTRAP_ADMIN_PASSWORD=your-strong-password-change-immediately-after-first-login
