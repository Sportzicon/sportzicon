# Backend Environment Variables - Template
# Copy to .env.local and update with your local values
# Never commit actual secrets - use GCP Secret Manager for production

# Environment
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Public URLs
PUBLIC_API_URL=http://localhost:8080
WEB_APP_URL=http://localhost:5173

# JWT Secrets (min 16 chars, use strong random values in production)
JWT_ACCESS_SECRET=dev-access-secret-min-16-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-min-16-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=http://localhost:5173

# Rate Limiting (relaxed for development)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=50

# GCP
GCP_PROJECT_ID=sportivox-dev
FIRESTORE_EMULATOR_HOST=localhost:8081
STORAGE_EMULATOR_HOST=http://localhost:4443

# GCS Buckets
GCS_BUCKET_MEDIA=sportivox-media-dev
GCS_BUCKET_DOCS=sportivox-docs-dev
GCS_SIGNED_URL_TTL_MIN=15
MAX_UPLOAD_MB=10

# Optional API Keys (leave empty if not using)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

EMAIL_FROM=no-reply@sportivox.local
EMAIL_FROM_NAME=Sportivox

# Resend — required for password reset and verification emails to actually send.
# Leave blank during development to use stub mode (emails are logged but not sent).
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redis (optional — leave blank to disable caching, app runs fine without it)
# REDIS_URL=redis://localhost:6379

# Bootstrap Admin (only for first setup, then clear)
BOOTSTRAP_ADMIN_EMAIL=admin@sportivox.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
