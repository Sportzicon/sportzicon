# Sportivox - Environment Variables
# Copy this file to .env in each service folder as needed.

# === Common ===
NODE_ENV=development
LOG_LEVEL=info

# === Backend ===
PORT=8080
# Public URL the frontend uses to reach the API
PUBLIC_API_URL=http://localhost:8080
# Public URL where the web app is served (used for email links + CORS)
WEB_APP_URL=http://localhost:5173

# JWT (generate strong random values for production via: openssl rand -base64 48)
JWT_ACCESS_SECRET=replace-me-with-64-bytes-of-random
JWT_REFRESH_SECRET=replace-me-with-another-64-bytes-of-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Bcrypt salt rounds (SRS requires >= 12)
BCRYPT_ROUNDS=12

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Rate limit (requests per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# === GCP ===
GCP_PROJECT_ID=sportivox-dev
GOOGLE_APPLICATION_CREDENTIALS=
# When set, Firestore SDK targets the emulator instead of GCP
FIRESTORE_EMULATOR_HOST=localhost:8081
# When set, GCS SDK targets fake-gcs-server emulator instead of GCP
STORAGE_EMULATOR_HOST=http://localhost:4443

# Storage
GCS_BUCKET_MEDIA=sportivox-media-dev
GCS_BUCKET_DOCS=sportivox-docs-dev
GCS_SIGNED_URL_TTL_MIN=15
MAX_UPLOAD_MB=10

# === Integrations ===
# OpenAI - billed to the client's account
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email - SendGrid
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@sportivox.local
EMAIL_FROM_NAME=Sportivox

# Admin bootstrap (used once on first run if no admin exists)
BOOTSTRAP_ADMIN_EMAIL=admin@sportivox.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# === Frontend (Vite) ===
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=Sportivox
