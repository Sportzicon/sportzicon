# Terraform Variables for Staging Environment
# Committed to Git — safe non-sensitive values only
# CI/CD pipeline updates api_image and web_image automatically on each push
# Secrets (JWT, API keys) live in GCP Secret Manager — never in this file

project_id = "sportzicon-app"
region     = "asia-south1"
env        = "staging"

# Docker image URLs (updated by CI/CD pipeline)
api_image = "asia-south1-docker.pkg.dev/sportzicon-app/sportivox/api:latest"
web_image = "asia-south1-docker.pkg.dev/sportzicon-app/sportivox/web:latest"

# Cloud Run scaling for staging
min_instances_api = 1
max_instances_api = 3

min_instances_web = 1
max_instances_web = 2

# API Configuration
api_port                = 8080
api_public_url          = "https://api.sportzicon.com"
web_app_url             = "https://sportzicon.com"
web_app_extra_origins   = ["https://www.sportzicon.com"]
cors_origins            = "https://sportzicon.com,https://www.sportzicon.com"

# Rate limiting (staging - more relaxed)
rate_limit_window_ms    = 900000
rate_limit_max          = 300
auth_rate_limit_max     = 20

# Logging level for staging
log_level               = "info"

# Email configuration — app password stored in Secret Manager
gmail_user      = "admin@sportzicon.com"
email_from      = "admin@sportzicon.com"
email_from_name = "Sportzicon"

# Optional secrets managed by Terraform (JWT keys are always created)
optional_secrets         = []
openai_api_key           = ""
bootstrap_admin_email    = ""
bootstrap_admin_password = ""

# Scoring API — built and deployed on every push to main
scoring_api_image          = "asia-south1-docker.pkg.dev/sportzicon-app/sportivox/scoring-api:latest"
scoring_api_custom_domain  = "scoring-api.sportzicon.com"
scoring_cors_origin        = "*"
optional_scoring_secrets   = []

# GCP Terraform state bucket
gcs_bucket_terraform_state = "sportivox-terraform-state-sportzicon-app"
