# Terraform Variables for Production Environment
# The CI/CD pipeline copies this file to terraform.tfvars.prod and updates image URLs
# DO NOT add real secrets here — use GCP Secret Manager

project_id = "sportivox-app"
region     = "asia-south1"
env        = "prod"

# Docker image URLs (updated by CI/CD pipeline on each tag)
api_image = "asia-south1-docker.pkg.dev/sportivox-app/sportivox/api:latest"
web_image = "asia-south1-docker.pkg.dev/sportivox-app/sportivox/web:latest"

# Cloud Run scaling (production)
min_instances_api = 1
max_instances_api = 5

min_instances_web = 1
max_instances_web = 3

# API Configuration — real Cloud Run URLs
api_port       = 8080
api_public_url = "https://placeholder.run.app"
web_app_url    = "https://placeholder.run.app"
cors_origins   = "https://placeholder.run.app"

# Rate limiting (production — strict)
rate_limit_window_ms = 900000
rate_limit_max       = 100
auth_rate_limit_max  = 10

# Logging
log_level = "warn"

# Which optional secrets to create in Secret Manager
# Add names here when you have real API keys: ["OPENAI_API_KEY", "SENDGRID_API_KEY"]
optional_secrets = []

# Secret values — only used when name is in optional_secrets above
openai_api_key           = ""
sendgrid_api_key         = ""
bootstrap_admin_email    = ""
bootstrap_admin_password = ""

# GCP Terraform state bucket
gcs_bucket_terraform_state = "sportivox-terraform-state-sportivox-app"
