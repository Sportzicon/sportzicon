# Terraform Variables for Production Environment
# The CI/CD pipeline copies this file to terraform.tfvars.prod and updates image URLs
# DO NOT add real secrets here — use GCP Secret Manager

project_id = "sportzicon-app"
region     = "asia-south1"
env        = "prod"

# Docker image URLs (updated by CI/CD pipeline on each tag)
api_image = "asia-south1-docker.pkg.dev/sportzicon-app/sportivox/api:latest"
web_image = "asia-south1-docker.pkg.dev/sportzicon-app/sportivox/web:latest"

# Cloud Run scaling (production)
min_instances_api = 1
max_instances_api = 5

min_instances_web = 1
max_instances_web = 3

# API Configuration
api_port       = 8080
api_public_url = "https://api.sportzicon.com"
web_app_url    = "https://sportzicon.com"
cors_origins   = "https://sportzicon.com"

# Rate limiting (production — strict)
rate_limit_window_ms = 900000
rate_limit_max       = 100
auth_rate_limit_max  = 10

# Logging
log_level = "warn"

# Email configuration
gmail_user      = "admin@sportzicon.com"
email_from      = "admin@sportzicon.com"
email_from_name = "Sportzicon"

# Which optional secrets to create in Secret Manager
optional_secrets = []

# Secret values — only used when name is in optional_secrets above
openai_api_key           = ""
sendgrid_api_key         = ""
bootstrap_admin_email    = ""
bootstrap_admin_password = ""

# GCP Terraform state bucket
gcs_bucket_terraform_state = "sportivox-terraform-state-sportzicon-app"
