# Copy this to .env and fill in the values.
# For local dev using docker-compose, these defaults work as-is.

# connection_limit/pool_timeout tune Prisma's connection pool — without them
# Prisma defaults to num_cpus*2+1 connections, which under load queues
# requests waiting for a free connection. Raise connection_limit if Cloud Run
# max instances * this value would exceed your Postgres max_connections.
DATABASE_URL=postgresql://sportivox:localdev@localhost:5432/sportivox?connection_limit=10&pool_timeout=20
